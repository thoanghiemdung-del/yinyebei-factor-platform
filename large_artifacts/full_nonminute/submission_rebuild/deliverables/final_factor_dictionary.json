  "factors": [
    {
      "factor_key": "factor_01",
      "factor_name_zh": "大单执行压力",
      "formula": "-0.250000 * z(F6_4_large_trade_ratio) -0.250000 * z(F_COMBO_8_large_trade) -0.250000 * z(N5_log_avg_ticket) +0.250000 * z(N6_large_ticket_amount_ratio)",
      "submitted_meaning": "综合大额成交占比、方向性大单和平均单笔金额，检验机构式大单执行压力。",
      "oos_pearson_ic": 0.0283930906504471,
      "oos_annual_excess": 0.2600328052104566,
      "oos_excess_sharpe": 6.246883384694906,
      "children": [
        {
          "leaf": "F6_4_large_trade_ratio",
          "weight": -0.25,
          "source_fields": "MINUTE_VOLUME",
          "raw_formula": "sum(volume where volume > 2 * median(minute_volume)) / sum(volume)",
          "meaning": "大额成交分钟的成交量占比，刻画大额执行集中度。"
        },
        {
          "leaf": "F_COMBO_8_large_trade",
          "weight": -0.25,
          "source_fields": "MINUTE_VOLUME, MINUTE_OPEN, MINUTE_CLOSE",
          "raw_formula": "F6_4_large_trade_ratio * sign(intraday_return)",
          "meaning": "大额成交占比与日内方向结合，刻画大单推动。"
        },
        {
          "leaf": "N5_log_avg_ticket",
          "weight": -0.25,
          "source_fields": "MINUTE_AMOUNT, MINUTE_NUMBER",
          "raw_formula": "log1p(sum(minute_amount) / sum(minute_number))",
          "meaning": "全日平均单笔金额的对数，刻画平均订单规模。"
        },
        {
          "leaf": "N6_large_ticket_amount_ratio",
          "weight": 0.25,
          "source_fields": "MINUTE_AMOUNT, MINUTE_NUMBER",
          "raw_formula": "sum(amount where amount/number > 2*median(bar_amount/bar_number)) / sum(amount)",
          "meaning": "异常大单时段成交额占比，刻画机构式大单执行。"
        }
      ]
    },
    {
      "factor_key": "factor_02",
      "factor_name_zh": "日内反转与成交笔数时序",
      "formula": "-0.166667 * z(F1_1_first30_mom) -0.166667 * z(F1_2_last30_mom) -0.166667 * z(F1_3_intraday_mom) +0.100000 * z(N1_count_weighted_time) -0.100000 * z(N2_open_count_ratio) -0.100000 * z(N3_close_count_ratio) -0.100000 * z(N4_count_hhi) -0.100000 * z(N7_count_price_corr)",
      "submitted_meaning": "将早盘、尾盘和全日日内反转与成交笔数时序结合，检验价格偏离是否得到广泛参与确认。",
      "oos_pearson_ic": 0.0201388620562343,
      "oos_annual_excess": 0.1681693921835851,
      "oos_excess_sharpe": 2.775120776738647,
      "children": [
        {
          "leaf": "F1_1_first30_mom",
          "weight": -0.16666666666666666,
          "source_fields": "MINUTE_OPEN, MINUTE_CLOSE",
          "raw_formula": "(close_at_minute_30 - open_at_minute_1) / open_at_minute_1",
          "meaning": "前30分钟收益，反映隔夜信息进入市场后的早盘价格压力。"
        },
        {
          "leaf": "F1_2_last30_mom",
          "weight": -0.16666666666666666,
          "source_fields": "MINUTE_OPEN, MINUTE_CLOSE",
          "raw_formula": "(close_at_last_minute - open_at_last_30min_start) / open_at_last_30min_start",
          "meaning": "后30分钟收益，反映尾盘调仓和集中执行造成的价格压力。"
        },
        {
          "leaf": "F1_3_intraday_mom",
          "weight": -0.16666666666666666,
          "source_fields": "MINUTE_OPEN, MINUTE_CLOSE",
          "raw_formula": "(close_at_last_minute - open_at_first_minute) / open_at_first_minute",
          "meaning": "从开盘到收盘的日内收益，刻画当日订单流推动的价格偏离。"
        },
        {
          "leaf": "N1_count_weighted_time",
          "weight": 0.1,
          "source_fields": "MINUTE_NUMBER",
          "raw_formula": "sum(minute_index * minute_number) / sum(minute_number) / (bars - 1)",
          "meaning": "成交笔数加权平均交易时点，刻画普通交易参与偏早盘还是尾盘。"
        },
        {
